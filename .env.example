ENVIRONMENT=local
DATABASE_URL=sqlite:///./icore-local.db
AUTH_SECRET_KEY=local-only-change-me-at-least-32-characters
SINGLE_USER_MODE_ENABLED=true
SINGLE_USER_USERNAME=admin
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production Google login. Keep these empty for local single-user mode.
GOOGLE_OAUTH_CLIENT_ID=
ALLOWED_LOGIN_DOMAINS=iceu.kr,iceu.co.kr
GOOGLE_LOGIN_ALLOWED_EMAILS=

ENVIRONMENT=local
DATABASE_URL=sqlite:///./icore-local.db
AUTH_SECRET_KEY=local-only-change-me-at-least-32-characters
SINGLE_USER_MODE_ENABLED=true
SINGLE_USER_USERNAME=admin
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Production Google login. Keep these empty for local single-user mode.
GOOGLE_OAUTH_CLIENT_ID=
ALLOWED_LOGIN_DOMAINS=iceu.kr,iceu.co.kr
GOOGLE_LOGIN_ALLOWED_EMAILS=

# 사전규격 API는 명시적으로 활성화하기 전까지 라우터가 등록되지 않습니다.
G2B_PRE_SPECIFICATIONS_ENABLED=false
G2B_PRE_SPEC_SERVICE_KEY=

# 나라장터 입찰공고 수집기 (실제 인증키는 .env 또는 비밀 관리 도구에만 입력)
G2B_SERVICE_KEY=
G2B_API_BASE_URL=https://apis.data.go.kr/1230000/ad/BidPublicInfoService
G2B_LOOKBACK_DAYS=14

# 선택 공고 Google Sheets 저장 기능 (서비스 계정 JSON은 Git에 포함하지 않음)
GSHEET_SERVICE_ACCOUNT_FILE=.secrets/google-service-account.json
GSHEET_ID=
GSHEET_TAB_NAME=나라장터 공고 수집 목록
